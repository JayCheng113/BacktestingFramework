#!/bin/sh
# Prevent accidental commit of full A-share parquet (>20MB)
# All-ETF seed is ~16MB (314 symbols, 11 years); full A-share is ~136MB (5700 symbols)
MAX_SIZE=20971520  # 20MB
for f in data/cache/*.parquet; do
    if [ -f "$f" ] && git diff --cached --name-only | grep -q "$f"; then
        size=$(wc -c < "$f" | tr -d ' ')
        if [ "$size" -gt "$MAX_SIZE" ]; then
            echo "BLOCKED: $f is ${size} bytes (>20MB). Full A-share parquet should not be committed."
            echo "Only ETF seed data (<20MB) should be in git."
            echo "Run: git reset HEAD data/cache/"
            exit 1
        fi
    fi
done
